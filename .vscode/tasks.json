{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "sample",
            "type": "pickString",
            "description": "Sample to build",
            "options": ["ble_advertiser"],
            "default": "ble_advertiser"
        }
    ],
    "tasks": [
        {
            "label": "Build firmware",
            "type": "shell",
            "command": "docker compose run --rm -e SAMPLE=${input:sample} zephyr ./scripts/build.sh",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm -rf build",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Memory report",
            "type": "shell",
            "command": "docker compose run --rm -e SAMPLE=${input:sample} zephyr ./scripts/memory_report.sh",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Memory report (verbose)",
            "type": "shell",
            "command": "docker compose run --rm -e SAMPLE=${input:sample} zephyr ./scripts/memory_report.sh --verbose",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
